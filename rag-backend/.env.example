# Application Settings
DEBUG=True

# MongoDB Settings
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB=xai_rag

# Embedding Model
EMBEDDING_MODEL=allenai/scibert_scivocab_uncased

# FAISS Settings
FAISS_INDEX_PATH=./data/faiss_index.bin

# Retrieval Settings
TOP_K=5

# =============================================================================
# API SETTINGS
# =============================================================================

# OpenAlex API (Primary Source)
# Docs: https://openalex.org/
# Base: https://api.openalex.org
# Rate: 100k credits/day with key, 100 credits/day without
# Cost: list request = 10 credits, singleton request = 1 credit
# Get free key at: https://openalex.org/settings/api
OPENALEX_API_KEY=your_openalex_api_key_here
OPENALEX_BASE_URL=https://api.openalex.org

# Semantic Scholar API (Alternative Source)
# Docs: https://api.semanticscholar.org/api-docs/datasets
# Base: https://api.semanticscholar.org/graph/v1
# Rate: 100 requests/5 minutes without key
# Get API key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

# Default Paper Source (openalex or semantic_scholar)
DEFAULT_PAPER_SOURCE=openalex